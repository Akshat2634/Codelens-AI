{
  "name": "codelens-ai",
  "version": "0.8.14",
  "description": "Correlate AI coding agent token usage with git output to measure ROI",
  "type": "module",
  "bin": {
    "codelens-ai": "src/index.js",
    "claude-roi": "src/index.js"
  },
  "main": "./src/index.js",
  "scripts": {
    "start": "node src/index.js",
    "dev": "node src/index.js --no-open",
    "lint": "biome check src/ tests/",
    "lint:fix": "biome check --write src/ tests/",
    "test:unit": "node --test tests/unit/*.test.js",
    "test:e2e": "playwright test",
    "test:e2e:local": "E2E_DIR=./tests/local playwright test",
    "test": "npm run lint && npm run test:unit && CI=1 npm run test:e2e"
  },
  "keywords": [
    "codelens",
    "claude",
    "codex",
    "cursor",
    "ai",
    "roi",
    "productivity",
    "tokens",
    "cost",
    "git",
    "dashboard"
  ],
  "author": "Akshat Sahu",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Akshat2634/Codelens-AI.git"
  },
  "bugs": {
    "url": "https://github.com/Akshat2634/Codelens-AI/issues"
  },
  "homepage": "https://codelensai-dev.vercel.app/",
  "engines": {
    "node": ">=18.0.0"
  },
  "dependencies": {
    "commander": "^13.0.0",
    "express": "^5.0.0",
    "open": "^10.0.0"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.13",
    "@playwright/test": "^1.59.1",
    "playwright": "^1.59.1"
  },
  "overrides": {
    "path-to-regexp": "^8.4.0"
  }
}
